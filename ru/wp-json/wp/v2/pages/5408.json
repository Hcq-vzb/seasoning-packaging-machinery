\u0435 \u043d\u0430\u043f\u043e\u043b\u043d\u0435\u043d\u0438\u0435, \u0443\u0441\u0442\u0430\u043d\u043e\u0432\u043a\u0443 \u0432\u043d\u0443\u0442\u0440\u0435\u043d\u043d\u0435\u0439 \u043f\u0440\u043e\u0431\u043a\u0438 \u0438 \u0437\u0430\u043a\u0430\u0442\u044b\u0432\u0430\u043d\u0438\u0435\/\u0433\u0435\u0440\u043c\u0435\u0442\u0438\u0437\u0430\u0446\u0438\u044e \u0432 \u043e\u0434\u043d\u043e\u043c \u0443\u0441\u0442\u0440\u043e\u0439\u0441\u0442\u0432\u0435. \u041f\u043e\u0441\u043b\u0435 \u043c\u043d\u043e\u0433\u043e\u043b\u0435\u0442\u043d\u0435\u0433\u043e \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u044f \u0443\u043f\u0430\u043a\u043e\u0432\u043e\u0447\u043d\u043e\u0439 \u043e\u0442\u0440\u0430\u0441\u043b\u0438 \u0438 \u0441\u043e\u0432\u0435\u0440\u0448\u0435\u043d\u0441\u0442\u0432\u043e\u0432\u0430\u043d\u0438\u044f \u0441\u0442\u0430\u043d\u0434\u0430\u0440\u0442\u043e\u0432 \u043c\u044b \u0434\u043e\u0431\u0430\u0432\u0438\u043b\u0438 \u0432 \u044d\u0442\u0443 \u043c\u043e\u043d\u043e\u0431\u043b\u043e\u0447\u043d\u0443\u044e \u043c\u0430\u0448\u0438\u043d\u0443 \u043e\u043f\u0446\u0438\u044e \u043f\u0440\u043e\u043c\u044b\u0432\u043a\u0438\/\u043e\u0447\u0438\u0441\u0442\u043a\u0438, \u043f\u043e\u044d\u0442\u043e\u043c\u0443 \u0435\u0451 \u0442\u0430\u043a\u0436\u0435 \u043c\u043e\u0436\u043d\u043e \u043d\u0430\u0437\u0432\u0430\u0442\u044c 4-\u0432-1.<br \/>\u041c\u043e\u043d\u043e\u0431\u043b\u043e\u0447\u043d\u044b\u0435 \u043c\u0430\u0448\u0438\u043d\u044b \u0434\u043b\u044f \u043d\u0430\u043f\u043e\u043b\u043d\u0435\u043d\u0438\u044f \u0444\u043b\u0430\u043a\u043e\u043d\u043e\u0432 \u043f\u043e\u043c\u043e\u0433\u0430\u044e\u0442 \u043f\u0440\u043e\u0438\u0437\u0432\u043e\u0434\u0438\u0442\u0435\u043b\u044f\u043c \u043e\u043f\u0442\u0438\u043c\u0438\u0437\u0438\u0440\u043e\u0432\u0430\u0442\u044c \u0437\u0430\u043d\u0438\u043c\u0430\u0435\u043c\u0443\u044e \u043f\u043b\u043e\u0449\u0430\u0434\u044c, \u0441\u043e\u043a\u0440\u0430\u0442\u0438\