043f\u0440\u0438\u043e\u0431\u0440\u0435\u0441\u0442\u0438 \u044d\u0442\u0438 \u043c\u0430\u0448\u0438\u043d\u044b. \u0412 \u0446\u0435\u043b\u043e\u043c, \u0435\u0441\u043b\u0438 \u0432\u0430\u0448 \u043c\u0430\u0442\u0435\u0440\u0438\u0430\u043b \u0442\u043e\u043d\u043a\u0438\u0439 \u0438\u043b\u0438 \u043f\u043e\u043b\u0443\u0432\u044f\u0437\u043a\u0438\u0439, \u0438\u043b\u0438 \u0435\u0441\u043b\u0438 \u0432\u0430\u043c \u043d\u0443\u0436\u043d\u0430 \u0431\u043e\u043b\u0435\u0435 \u0443\u043d\u0438\u0432\u0435\u0440\u0441\u0430\u043b\u044c\u043d\u0430\u044f \u043c\u0430\u0448\u0438\u043d\u0430, \u0432\u044b \u043c\u043e\u0436\u0435\u0442\u0435 \u0432\u044b\u0431\u0440\u0430\u0442\u044c \u043f\u043e\u0440\u0448\u043d\u0435\u0432\u0443\u044e \u0444\u0430\u0441\u043e\u0432\u043e\u0447\u043d\u0443\u044e \u043c\u0430\u0448\u0438\u043d\u0443.<\/p>\n\n\n\n<p class=\"wp-block-paragraph\">\u0415\u0441\u043b\u0438 \u0432\u0430\u0448 \u043f\u0440\u043e\u0434\u0443\u043a\u0442 \u0432\u044f\u0437\u043a\u0438\u0439 \u0438\u043b\u0438 \u0441\u043e\u0434\u0435\u0440\u0436\u0438\u0442 \u043e\u043f\u0440\u0435\u0434\u0435\u043b\u0435\u043d\u043d\u044b\u0435 \u0447\u0430\u0441\u0442\u0438\u0446\u044b, \u0438 \u0432\u044b \u0437\u0430\u0431\u043e\u0442\u0438\u0442\u0435\u0441\u044c \u043e\u0431 \u043e\u0447\u0438\u0441\u0442\u043a\u0435, \u0442\u043e \u0440\u043e\u0442\u043e\u0440\u043d\u044b\u0439 \u043d\u0430\u0441\u043e\u0441 \u0434\u043b\u044f \u0440\u043e\u0437\u043b\u0438\u0432\u0430 - \u0432\u0430\u0448 \u043b\u0443\u0447\u0448\u0438\u0439 \u0432\u044b\u0431\u043e\u0440.<\/p>\n\n\n\n<p class=\"wp-block-paragraph\">\u041d\u0430 \u0440\u044b\u043d\u043a\u0435 \u043f\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043b\u0435\u043d\u043e \u043c\u043d\u043e\u0436\u0435\u0441\u0442\u0432\u043e \u0442\u0438\u043f\u043e\u0432 \u0444\u0430\u0441\u043e\u0432\u043e\u0447\u043d\u044b\u0445 \u043c\u0430\u0448\u0438\u043d, \u0438 \u043e\u0447\u0435\u043d\u044c \u0432\u0430\u0436\u043d\u043e \u043d\u0435 \u043f\u043e\u043a\u0443\u043f\u0430\u0442\u044c \u0438\u0445 \u0432\u0441\u043b\u0435\u043f\u0443\u044e, \u043d\u0435 \u0440\u0430\u0437\u043e\u0431\u0440\u0430\u0432\u0448\u0438\u0441\u044c \u0432 \u043d\u0438\u0445. \u0412\u044b\u0431\u043e\u0440 \u043f\u0440\u0430\u0432\u0438\u043b\u044c\u043d\u043e\u0439 \u043c\u0430\u0448\u0438\u043d\u044b \u0432 \u0437\u0430\u0432\u0438\u0441\u0438\u043c\u043e\u0441\u0442\u0438 \u043e\u0442 \u0432\u0430\u0448\u0438\u0445 \u043f\u043e\u0442\u0440\u0435\u0431\u043d\u043e\u0441\u0442\u0435\u0439 \u0438\u043c\u0435\u0435\u0442 \u0440\u0435\u0448\u0430\u044e\u0449\u0435\u0435 \u0437\u043d\u0430\u0447\u0435\u043d\u0438\u0435. \u041d\u0435\u043e\u0431\u0445\u043e\u0434\u0438\u043c\u043e \u0443\u0447\u0438\u0442\u044b\u0432\u0430\u0442\u044c \u0442\u0430\u043a\u0438\u0435 \u0444\u0430\u043a\u0442\u043e\u0440\u044b, \u043a\u0430\u043a \u0442\u0438\u043f \u043f\u0440\u043e\u0434\u0443\u043a\u0442\u0430, \u0432\u044f\u0437\u043a\u043e\u0441\u0442\u044c, \u043a\u0438\u0441\u043b\u043e\u0442\u043d\u043e\u0441\u0442\u044c \u0438 \u0449\u0435\u043b\u043e\u0447\u043d\u043e\u0441\u0442\u044c, \u0430 \u0442\u0430\u043a\u0436\u0435 \u0440\u0430\u0437\u043c\u0435\u0440 \u0431\u0443\u0442\u044b\u043b\u043a\u0438. \u0415\u0441\u043b\u0438 \u0443 \u0432\u0430\u0441 \u0435\u0441\u0442\u044c \u043a\u0430\u043a\u0438\u0435-\u043b\u0438\u0431\u043e \u043f\u0440\u043e\u0431\u043b\u0435\u043c\u044b \u0438\u043b\u0438 \u0432\u043e\u043f\u0440\u043e\u0441\u044b, \u043f\u043e\u0436\u0430\u043b\u0443\u0439\u0441\u0442\u0430, \u043e\u0431\u0440\u0430\u0449\u0430\u0439\u0442\u0435\u0441\u044c \u043a \u043d\u0430\u043c \u0432 \u043b\u044e\u0431\u043e\u0435 \u0432\u0440\u0435\u043c\u044f. \u041c\u044b \u043f\u043e\u043c\u043e\u0436\u0435\u043c \u0432\u0430\u043c \u0440\u0430\u0437\u0440\u0430\u0431\u043e\u0442\u0430\u0442\u044c \u043e\u043f\u0442\u0438\u043c\u0430\u043b\u044c\u043d\u043e\u0435 \u0440\u0435\u0448\u0435\u043d\u0438\u0435, \u0441\u043e