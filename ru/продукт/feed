									<table><tbody><tr><td>1</td><td>Мощность</td><td>≤2,3 кВт (включая вакуумный насос)</td></tr><tr><td>2</td><td>Производительность/Ёмкость</td><td>2200-2400 BPH</td></tr><tr><td>3</td><td>Диаметр Крышки</td><td>￠30-￠55 мм ￠50-￠85 мм</td></tr><tr><td>4</td><td>Высота бутылки</td><td>80-250 мм</td></tr><tr><td>5</td><td>Диаметр бутылки</td><td>￠30-￠85 мм</td></tr><tr><td>5</td><td>Максимальный вакуум</td><td>-0,08 мпа</td></tr><tr><td>6</td><td>Момент затяжки</td><td>5-20N.M</td></tr><tr><td>7</td><td>Расход воздуха</td><td>0,6M3/0,7Mpa</td></tr><tr><td>9</td><td>Габариты</td><td>about2100×900×1630mm 750X1060X1400mm</td></tr><tr><td>10</td><td>Вес</td><td>около 850 кг</td></tr></tbody></table>								</div>
