					<h2 class="elementor-heading-title elementor-size-default">Горизонтальные машины для наполнения и запайки пакетов</h2>				</div>
				<div class="elementor-element elementor-element-404163cc elementor-widget-divider--view-line elementor-widget elementor-widget-divider" data-id="404163cc" data-element_type="widget" data-e-type="widget" data-widget_type="divider.default">
