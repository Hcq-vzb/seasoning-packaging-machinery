									<table><tbody><tr><td colspan="4">Технические параметры</td></tr><tr><td>Скорость</td><td colspan="3">60-350 шт/мин (в зависимости от длины этикетки и толщины бутылки)</td></tr><tr><td>Высота </td><td colspan="3">30-350 мм</td></tr><tr><td>Толщина объекта</td><td colspan="3">20-120 мм</td></tr><tr><td>Высота этикетки</td><td colspan="3">15-140 мм</td></tr><tr><td>Длина этикетки</td><td colspan="3">25-300 мм</td></tr><tr><td>Внутренний диаметр рулона этикеток</td><td colspan="3">76 мм</td></tr><tr><td>Внешний диаметр рулона этикеток</td><td colspan="3">420 мм</td></tr><tr><td>Точность</td><td colspan="3">±1 мм</td></tr><tr><td>Мощность </td><td colspan="3">220V 50/60HZ 3.5KW Однофазный</td></tr><tr><td>Расход воздуха </td><td colspan="3">5 кг/см^2</td></tr><tr><td>Габариты</td><td colspan="3">2800(L)×1650(W)×1500(H)mm</td></tr><tr><td>Вес </td><td colspan="3">450 кг</td></tr></tbody></table>								</div>
