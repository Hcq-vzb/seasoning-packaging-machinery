									<table><tbody><tr><td>1</td><td>Power</td><td>≤2.3KW(including the vacuum pump)</td></tr><tr><td>2</td><td>Capacity</td><td>2200-2400 BPH</td></tr><tr><td>3</td><td>Cap Diameter</td><td>￠30-￠55mm ￠50-￠85mm</td></tr><tr><td>4</td><td>Bottle height</td><td>80-250mm</td></tr><tr><td>5</td><td>Bottle diameter</td><td>￠30-￠85mm</td></tr><tr><td>5</td><td>Max vacuum</td><td>-0.08mpa</td></tr><tr><td>6</td><td>Capping torsion</td><td>5-20N.M</td></tr><tr><td>7</td><td>Air consumption</td><td>0.6M3/0.7Mpa</td></tr><tr><td>9</td><td>Dimensions</td><td>about2100×900×1630mm 750X1060X1400mm</td></tr><tr><td>10</td><td>Weight</td><td>about 850kg</td></tr></tbody></table>								</div>
