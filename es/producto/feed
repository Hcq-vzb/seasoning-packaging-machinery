									<table><tbody><tr><td>Modelo</td><td>NP-HGL</td></tr><tr><td>Volumen de botella adecuado</td><td>265ml±4ml</td></tr><tr><td>Velocidad</td><td>6000 -10000 botellas/hora</td></tr><tr><td>Forma de la botella</td><td>Botella redonda</td></tr><tr><td>Diámetro de la botella</td><td>55mm-100mm</td></tr><tr><td>Precisión</td><td>2 mm</td></tr><tr><td>Material aplicable de la etiqueta</td><td>PAPEL, PP, BOPP, OPP, PVC, PE, ETC.</td></tr><tr><td>Material aplicable de la botella</td><td>PE, PET, Botella de vidrio, Lata POP</td></tr><tr><td>Potencia</td><td>308 VOLTIOS, TRIFÁSICO, 50-60 HZ, 9 -12 KW</td></tr><tr><td>Consumo de aire</td><td>4Mpa</td></tr><tr><td>Peso</td><td>1500 Kg</td></tr><tr><td>Dimensiones</td><td>L5000 × An1800 × Al2000 mm incluido el coneyor</td></tr></tbody></table>								</div>
