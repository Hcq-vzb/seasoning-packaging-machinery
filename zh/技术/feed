		<link>https://www.npackpm.com/zh/%e5%85%b3%e4%ba%8e%e5%8c%96%e5%a6%86%e5%93%81%e7%81%8c%e8%a3%85%e6%9c%ba%e7%9a%84%e7%8b%ac%e7%89%b9%e6%8c%87%e5%8d%97-html</link>
		
		<dc:creator><![CDATA[Shanghai npack Automation Equipment Co.,ltd]]></dc:creator>
