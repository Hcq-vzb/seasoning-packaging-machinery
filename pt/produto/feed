									<table><tbody><tr><td colspan="4">Parâmetros técnicos</td></tr><tr><td>Velocidade</td><td colspan="3">60-350pcs/min (dependendo do comprimento do rótulo e da espessura da garrafa)</td></tr><tr><td>Altura </td><td colspan="3">30-350mm</td></tr><tr><td>Espessura do objeto</td><td colspan="3">20-120 mm</td></tr><tr><td>Altura do rótulo</td><td colspan="3">15-140 mm</td></tr><tr><td>Comprimento do rótulo</td><td colspan="3">25-300 mm</td></tr><tr><td>Diâmetro interno do rolo de etiquetas</td><td colspan="3">76 mm</td></tr><tr><td>Diâmetro externo do rolo de etiquetas</td><td colspan="3">420 mm</td></tr><tr><td>Precisão</td><td colspan="3">±1mm</td></tr><tr><td>Potência </td><td colspan="3">220V 50/60HZ 3,5KW Monofásico</td></tr><tr><td>Consumo de ar </td><td colspan="3">5Kg/cm^2</td></tr><tr><td>Dimensões</td><td colspan="3">2800(L)×1650(W)×1500(H)mm</td></tr><tr><td>Peso </td><td colspan="3">450Kg</td></tr></tbody></table>								</div>
