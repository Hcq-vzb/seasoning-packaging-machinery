									<table><tbody><tr><td>Modelo</td><td>NP-HGL</td></tr><tr><td>Volume de garrafa adequado</td><td>265ml±4ml</td></tr><tr><td>Velocidade</td><td>6000 -10000garrafas/hora</td></tr><tr><td>Formato da garrafa</td><td>Garrafa redonda</td></tr><tr><td>Diâmetro da garrafa</td><td>55mm-100mm</td></tr><tr><td>Precisão</td><td>2mm</td></tr><tr><td>Material aplicável do rótulo</td><td>PAPEL, PP, BOPP, OPP, PVC, PE, ETC</td></tr><tr><td>Material aplicável da garrafa</td><td>PE, PET, garrafa de vidro, lata POP</td></tr><tr><td>Potência</td><td>308 VOLTS, 3 FASES, 50-60 HZ, 9 -12 KW</td></tr><tr><td>Consumo de ar</td><td>4Mpa</td></tr><tr><td>Peso</td><td>1500 kg</td></tr><tr><td>Dimensões</td><td>L5000 × L1800 × A2000 mm, incluindo o coneyor</td></tr></tbody></table>								</div>
